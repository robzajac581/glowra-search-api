DB_DRIVER='{ODBC Driver 17 for SQL Server}'
DB_SERVER=your_server_here
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password
NODE_ENV=production

# Optional: canonical URLs for blog HTML, OG tags, and sitemap (e.g. https://www.glowra.com)
# If unset, the request Host / X-Forwarded-Proto headers are used.
PUBLIC_SITE_URL=

# Optional: Vercel (or other) deploy hook after blog publish/update/delete (see utils/deployWebhook.js)
FE_DEPLOY_HOOK_URL=